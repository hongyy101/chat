{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI 调试",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--reload",
                "--port",
                "8000",
                "--host",
                "127.0.0.1"
